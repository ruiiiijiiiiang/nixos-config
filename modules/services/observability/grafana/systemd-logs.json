{
  "uid": "systemd-logs-viewer",
  "title": "Systemd Logs Viewer",
  "tags": ["loki", "systemd"],
  "timezone": "",
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"systemd-journal\"}, host)",
        "query": "label_values({job=\"systemd-journal\"}, host)",
        "options": [],
        "hide": 0,
        "refresh": 1,
        "sort": 1,
        "skipUrlSync": false,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "unit",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"systemd-journal\", host=~\"$host\"}, unit)",
        "query": "label_values({job=\"systemd-journal\", host=~\"$host\"}, unit)",
        "options": [],
        "hide": 0,
        "refresh": 1,
        "sort": 1,
        "skipUrlSync": false,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "logs",
      "title": "Journal Output: $unit on $host",
      "datasource": "Loki",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "{job=\"systemd-journal\", host=~\"$host\", unit=~\"$unit\"}"
        }
      ]
    }
  ]
}
